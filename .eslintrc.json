{
  "env": {
    "node": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "extends": [
    "eslint:recommended",
    "plugin:prettier/recommended"
  ],
  "rules": {
    "no-return-assign": "off",
    "no-unused-vars": "warn",
    "no-param-reassign": ["error", { "props": false }]
  }
}